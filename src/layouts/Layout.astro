---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AttributionRuntime from "../components/AttributionRuntime.astro";
import PricingRuntime from "../components/PricingRuntime.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  lang?: string;
  locale?: string;
  page?: string;
  ogType?: "website" | "article";
  image?: string;
  alternates?: { locale: string; href: string }[];
  content?: any;
  schema?: Record<string, any>[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  lang = "en",
  locale = "en",
  page = "home",
  ogType = "website",
  image,
  alternates = [],
  content,
  schema = [],
} = Astro.props;
const siteUrl = Astro.site ?? new URL("https://websiteli.ch");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const imageUrl = new URL(image ?? "/assets/websiteli-og.png", siteUrl).toString();
const xDefaultHref = alternates.find((item) => item.locale === "en")?.href ?? "/en/";
const analyticsPagePath = page === "home" ? "/" : "";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Websiteli",
    url: siteUrl.toString(),
    email: "info@websiteli.ch",
    telephone: "+41772653306",
    logo: new URL("/assets/websiteli-logo.png", siteUrl).toString(),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Websiteli",
    url: siteUrl.toString(),
    inLanguage: lang,
    potentialAction: {
      "@type": "SearchAction",
      target: new URL(`/${locale}/blog/?q={search_term_string}`, siteUrl).toString(),
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "Websiteli",
    url: siteUrl.toString(),
    email: "info@websiteli.ch",
    telephone: "+41772653306",
    areaServed: {
      "@type": "Country",
      name: "Switzerland",
    },
    priceRange: "Varies by market",
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Business websites, SEO setup, website maintenance and AI automation",
    provider: { "@type": "Organization", name: "Websiteli", url: siteUrl.toString() },
    areaServed: ["Switzerland", "Germany", "Austria", "Czech Republic", "Slovakia", "Hungary", "International"],
    serviceType: ["Website creation", "Website redesign", "Website maintenance", "Local SEO", "Lead generation", "AI automation", "Business automation"],
    description,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Who owns a Websiteli website?",
        acceptedAnswer: { "@type": "Answer", text: "The client owns the domain, hosting access, source code, analytics accounts and website assets unless a separate third-party service requires its own terms." },
      },
      {
        "@type": "Question",
        name: "Does Websiteli offer website maintenance?",
        acceptedAnswer: { "@type": "Answer", text: "Yes. Websiteli offers monthly website maintenance with security updates, monitoring, backups, performance checks, small content changes, analytics reports, SEO monitoring and technical support." },
      },
      {
        "@type": "Question",
        name: "Can Websiteli help with SEO and Google Business?",
        acceptedAnswer: { "@type": "Answer", text: "Yes. Websiteli sets up technical SEO basics, metadata, Google Analytics, Google Search Console and Google Business Profile support as part of growth-focused packages." },
      },
    ],
  },
  ...schema,
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#e32635" />
    <meta name="msapplication-TileColor" content="#e32635" />
    <meta name="msapplication-config" content="/browserconfig.xml?v=3" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/websiteli-logo.png?v=3" />
    <link rel="shortcut icon" type="image/png" href="/assets/websiteli-logo.png?v=3" />
    <link rel="apple-touch-icon" href="/assets/websiteli-logo.png?v=3" />
    <link rel="manifest" href="/site.webmanifest?v=3" />
    {alternates.map((item) => <link rel="alternate" hreflang={item.locale} href={new URL(item.href, siteUrl).toString()} />)}
    {alternates.length > 0 && <link rel="alternate" hreflang="x-default" href={new URL(xDefaultHref, siteUrl).toString()} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="websiteli.ch" />
    <meta property="og:locale" content={`${lang}_CH`} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <AttributionRuntime />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TGZY875FGJ"></script>
    <script is:inline define:vars={{ analyticsPagePath }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      const gtagConfig = {};
      const attribution = window.websiteliGetAttribution?.() || {};
      const attributionParams = window.websiteliGetAnalyticsAttributionParams?.(attribution) || {};
      if (analyticsPagePath) {
        const analyticsPageUrl = new URL(analyticsPagePath, window.location.origin);
        analyticsPageUrl.search = window.location.search;
        analyticsPageUrl.hash = window.location.hash;
        gtagConfig.page_path = analyticsPagePath;
        gtagConfig.page_location = analyticsPageUrl.toString();
      } else {
        gtagConfig.page_location = window.location.href;
      }
      if (attribution.utm_source) gtagConfig.campaign_source = attribution.utm_source;
      if (attribution.utm_medium) gtagConfig.campaign_medium = attribution.utm_medium;
      if (attribution.utm_campaign) gtagConfig.campaign_name = attribution.utm_campaign;
      if (attribution.utm_id) gtagConfig.campaign_id = attribution.utm_id;
      if (attribution.utm_term) gtagConfig.campaign_term = attribution.utm_term;
      if (attribution.utm_content) gtagConfig.campaign_content = attribution.utm_content;
      if (attribution.gclid) gtagConfig.gclid = attribution.gclid;
      if (attribution.fbclid) gtagConfig.fbclid = attribution.fbclid;
      if (attribution.referrer) gtagConfig.page_referrer = attribution.referrer;
      Object.entries(attributionParams).forEach(([key, value]) => {
        if (value) gtagConfig[key] = value;
      });
      if (new URLSearchParams(window.location.search).get('debug_mode') === 'true') {
        gtagConfig.debug_mode = true;
      }
      gtag('set', attributionParams);
      gtag('config', 'G-TGZY875FGJ', gtagConfig);
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.dataset.theme = storedTheme || (prefersDark ? "dark" : "light");
    </script>
    <script is:inline>
      function getWebsiteliEventAttribution() {
        const params = window.websiteliGetAnalyticsAttributionParams?.() || {};
        return Object.fromEntries(Object.entries(params).filter(([, value]) => Boolean(value)));
      }

      window.trackWebsiteliEvent = function(eventName, params = {}) {
        const eventParams = {
          ...getWebsiteliEventAttribution(),
          ...params,
        };
        if (new URLSearchParams(window.location.search).get("debug_mode") === "true") {
          eventParams.debug_mode = true;
        }

        if (typeof window.gtag === "function") {
          window.gtag("event", eventName, eventParams);
        }
      };

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target.closest("[data-track-event]") : null;
        if (!target) return;

        window.trackWebsiteliEvent(target.dataset.trackEvent, {
          event_category: target.dataset.trackCategory || "engagement",
          event_label: target.dataset.trackLabel || target.textContent?.trim() || "",
        });
      });

      document.addEventListener("DOMContentLoaded", () => {
        const pricing = document.querySelector("#pricing");
        if (!pricing || !("IntersectionObserver" in window)) return;

        const observer = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              window.trackWebsiteliEvent("pricing_section_view", {
                event_category: "engagement",
                event_label: "Pricing",
              });
              observer.disconnect();
            }
          },
          { threshold: 0.35 },
        );

        observer.observe(pricing);
      });
    </script>
    <title>{title}</title>
  </head>
  <body>
    <Header content={content} locale={locale} page={page} languageLinks={alternates} />
    <slot />
    <Footer content={content} locale={locale} />
    <PricingRuntime />
  </body>
</html>
