---
import { Buffer } from "node:buffer";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PricingCard from "../components/PricingCard.astro";
import ProcessStep from "../components/ProcessStep.astro";
import FAQ from "../components/FAQ.astro";
import CTASection from "../components/CTASection.astro";
import { addOns, faqs, localTrust, pricing, processSteps, reasons, services } from "../content/site";
import pricingTable from "../content/pricing.json";

const fallbackPlans = {
  landingPage: "from 1,000 CHF",
  businessWebsite: "from 2,000 CHF",
  premiumWebsite: "from 3,500 CHF",
  seoSetup: "from 500 CHF",
  maintenanceMonthly: "from 100 CHF/month",
};
const pricingCards = pricing.map((plan) => ({
  ...plan,
  price: fallbackPlans[plan.priceKey as keyof typeof fallbackPlans],
}));
const addOnCards = addOns.map((item) => ({
  ...item,
  price: "priceKey" in item ? fallbackPlans[item.priceKey as keyof typeof fallbackPlans] : item.price,
}));
const encodedPricingData = Buffer.from(JSON.stringify(pricingTable), "utf8")
  .toString("base64")
  .match(/.{1,80}/g) ?? [];
---

<Layout
  title="Websiteli — Simple Modern Websites for Swiss Businesses"
  description="Swiss-based developers building clean, modern websites for small businesses. Clear pricing, friendly support, and websites that are ready to grow."
  canonicalPath="/"
>
  <main>
    <Hero />

    <section class="intro-strip" aria-label="Key promise">
      <p>Your website should be easy to find, easy to understand, and easy to contact you from.</p>
    </section>

    <section class="section-shell section-block" id="services">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Everything your business needs to look professional online.</h2>
        <p>Start with a simple page today and grow into a bigger website later.</p>
      </div>
      <div class="service-grid">
        {services.map((service, index) => <ServiceCard {...service} index={index + 1} />)}
      </div>
    </section>

    <section class="section-shell section-block" id="pricing">
      <div class="section-heading centered">
        <p class="eyebrow">Pricing</p>
        <h2>Clear starting prices with room to grow.</h2>
        <p>We build websites for Swiss businesses that want to look professional online without overcomplicating things.</p>
      </div>
      <div class="pricing-grid">
        {pricingCards.map((plan) => <PricingCard {...plan} />)}
      </div>
      <div class="large-note">
        <strong>Need something bigger?</strong>
        <span>More pages, multiple languages, online shops, booking tools, automation, and custom features can be discussed individually.</span>
      </div>
      <p class="market-note">
        Pricing depends on your market, business needs, and project scope. Final quotes are confirmed after a short consultation.
      </p>
    </section>

    <section class="section-shell section-block add-ons">
      <div class="section-heading">
        <p class="eyebrow">Useful add-ons</p>
        <h2>Useful add-ons when you need them.</h2>
      </div>
      <div class="addon-grid">
        {addOnCards.map((item) => (
          <article class="addon-card">
            <h3>{item.title}</h3>
            <strong data-price-key={"priceKey" in item ? item.priceKey : undefined}>{item.price}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="why-section">
      <div class="section-shell why-inner">
        <div class="section-heading">
          <p class="eyebrow">Why choose us</p>
          <h2>Built by Swiss-based developers who keep things simple.</h2>
        </div>
        <div class="reason-grid">
          {reasons.map((reason) => <div>{reason}</div>)}
        </div>
      </div>
    </section>

    <section class="section-shell section-block local-trust">
      <div class="section-heading centered">
        <p class="eyebrow">Local trust</p>
        <h2>Practical website help for Swiss small businesses.</h2>
        <p>Clear pricing, friendly support, and a professional online presence without overcomplicating the process.</p>
      </div>
      <div class="trust-grid">
        {localTrust.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-shell section-block" id="process">
      <div class="section-heading centered">
        <p class="eyebrow">Process</p>
        <h2>A calm, clear way to get online.</h2>
      </div>
      <div class="process-grid">
        {processSteps.map((step, index) => <ProcessStep {...step} index={index + 1} />)}
      </div>
    </section>

    <section class="section-shell section-block faq-section">
      <div class="section-heading">
        <p class="eyebrow">Questions</p>
        <h2>Frequently asked questions.</h2>
      </div>
      <div class="faq-list">
        {faqs.map((faq) => <FAQ {...faq} />)}
      </div>
    </section>

    <CTASection />
  </main>

  <script define:vars={{ pricingDataSource: encodedPricingData }}>
    const pricingData = JSON.parse(atob(pricingDataSource.join("")));
    const marketCollectionKey = atob("bWFya2V0cw==");
    const fallbackKey = atob("ZGVmYXVsdE1hcmtldA==");
    const supportedPricingMarkets = new Set(Object.keys(pricingData[marketCollectionKey]));

    function getCookie(name) {
      return document.cookie
        .split(";")
        .map((part) => part.trim())
        .find((part) => part.startsWith(`${name}=`))
        ?.split("=")[1] || "";
    }

    function setMarketCookie(market) {
      document.cookie = `websiteli_market=${market}; Max-Age=2592000; Path=/; SameSite=Lax`;
    }

    function formatPrice(amount, currency) {
      return `${new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 }).format(amount)} ${currency}`;
    }

    function getPricingForMarket(market) {
      const resolvedMarket = supportedPricingMarkets.has(market) ? market : pricingData[fallbackKey];
      const pricing = pricingData[marketCollectionKey][resolvedMarket];

      return {
        market: resolvedMarket,
        plans: {
          landingPage: `from ${formatPrice(pricing.landingPage, pricing.currency)}`,
          businessWebsite: `from ${formatPrice(pricing.businessWebsite, pricing.currency)}`,
          premiumWebsite: `from ${formatPrice(pricing.premiumWebsite, pricing.currency)}`,
          seoSetup: `from ${formatPrice(pricing.seoSetup, pricing.currency)}`,
          maintenanceMonthly: `from ${formatPrice(pricing.maintenanceMonthly, pricing.currency)}/month`,
        },
      };
    }

    const marketLookups = [
      {
        name: "country.is",
        url: "https://api.country.is/",
        pick: (data) => data?.country,
      },
      {
        name: "ipwho.is",
        url: "https://ipwho.is/?fields=success,country_code",
        pick: (data) => data?.success === true ? data?.country_code : "",
      },
      {
        name: "ipapi.co",
        url: "https://ipapi.co/json/",
        pick: (data) => data?.country_code,
      },
    ];

    function normalizeMarket(value) {
      return typeof value === "string" ? value.trim().slice(0, 2).toUpperCase() : "";
    }

    async function fetchMarketFromLookup(lookup) {
      const response = await fetch(lookup.url, {
        cache: "no-store",
        headers: {
          Accept: "application/json",
        },
      });

      if (!response.ok) return { market: "", source: lookup.name };
      const data = await response.json();
      const market = normalizeMarket(lookup.pick(data));

      return {
        market: supportedPricingMarkets.has(market) ? market : "",
        source: lookup.name,
      };
    }

    async function detectBrowserMarket() {
      for (const lookup of marketLookups) {
        try {
          const result = await fetchMarketFromLookup(lookup);

          if (result.market) {
            return result;
          }
        } catch {
          // Try the next lookup service.
        }
      }

      return { market: "", source: "" };
    }

    function renderPricing(pricing) {
      const plans = pricing?.plans || {};

      document.querySelectorAll("[data-price-key]").forEach((element) => {
        const key = element instanceof HTMLElement ? element.dataset.priceKey : "";
        const price = key ? plans[key] : "";

        if (typeof price === "string" && price) {
          element.textContent = price;
        }
      });
    }

    async function updatePricing() {
      const urlParams = new URLSearchParams(window.location.search);
      const urlMarket = normalizeMarket(urlParams.get("market"));
      const cachedMarket = normalizeMarket(getCookie("websiteli_market"));
      const debugPricing = urlParams.get("pricing_debug") === "1";
      let market = supportedPricingMarkets.has(urlMarket) ? urlMarket : "";
      let source = market ? "url" : "";

      if (!supportedPricingMarkets.has(market)) {
        const detected = await detectBrowserMarket();
        market = detected.market;
        source = detected.source;
      }

      if (!supportedPricingMarkets.has(market) && cachedMarket !== "CH") {
        market = cachedMarket;
        source = "cookie";
      }

      if (supportedPricingMarkets.has(market)) {
        setMarketCookie(market);
      }

      renderPricing(getPricingForMarket(market));

      if (debugPricing) {
        console.info("Websiteli pricing", {
          market: supportedPricingMarkets.has(market) ? market : pricingData[fallbackKey],
          source: source || "fallback",
          cachedMarket,
          urlMarket,
        });
      }
    }

    updatePricing().catch(() => {});
  </script>
</Layout>
