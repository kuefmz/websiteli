---
import Layout from "../../../../layouts/Layout.astro";
import ArticleCTA from "../../../../components/ArticleCTA.astro";
import ArticleShare from "../../../../components/ArticleShare.astro";
import { getLocaleContent, getLocalizedPath, localeCodes, type LocaleCode } from "../../../../content/locales";
import { getBlogIndexContent, getBlogPost, getBlogPosts, getBlogSlugs, getHeadingId, renderBlogMarkdown } from "../../../../content/blog";

export async function getStaticPaths() {
  const slugs = await getBlogSlugs();
  return localeCodes.flatMap((locale) => slugs.map((slug) => ({ params: { locale, slug } })));
}

const locale = Astro.params.locale as LocaleCode;
const slug = Astro.params.slug as string;
const content = getLocaleContent(locale);
const blogContent = getBlogIndexContent(locale);
const post = await getBlogPost(locale, slug);

if (!post) {
  return Astro.redirect(getLocalizedPath(locale, "blog"));
}

const articleHtml = renderBlogMarkdown(post.body, locale);
const allPosts = await getBlogPosts(locale);
const postIndex = allPosts.findIndex((item) => item.slug === post.slug);
const nextPost = postIndex >= 0 && postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : undefined;
const canonicalLocale = post.isFallback ? "en" : locale;
const canonicalPath = `/${canonicalLocale}/blog/${post.slug}/`;
const siteUrl = Astro.site ?? new URL("https://websiteli.ch");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const imageUrl = new URL(post.featuredImage, siteUrl).toString();
const articleUi = {
  contents: locale === "de" ? "Inhalt" : locale === "hu" ? "Tartalom" : locale === "fr" ? "Sommaire" : locale === "es" ? "Contenido" : locale === "it" ? "Indice" : locale === "ja" ? "目次" : "Contents",
  summary: locale === "de" ? "Artikelzusammenfassung" : locale === "hu" ? "Cikk összefoglaló" : locale === "fr" ? "Résumé de l'article" : locale === "es" ? "Resumen del artículo" : locale === "it" ? "Riassunto dell'articolo" : locale === "ja" ? "記事の要約" : "Article summary",
  takeaways: locale === "de" ? "Wichtigste Erkenntnisse" : locale === "hu" ? "Fő tanulságok" : locale === "fr" ? "Points clés" : locale === "es" ? "Puntos clave" : locale === "it" ? "Punti chiave" : locale === "ja" ? "重要ポイント" : "Key takeaways",
  references: locale === "de" ? "Referenzen" : locale === "hu" ? "Hivatkozások" : locale === "fr" ? "Références" : locale === "es" ? "Referencias" : locale === "it" ? "Riferimenti" : locale === "ja" ? "参考リンク" : "References",
  updated: locale === "de" ? "Aktualisiert" : locale === "hu" ? "Frissítve" : locale === "fr" ? "Mis à jour" : locale === "es" ? "Actualizado" : locale === "it" ? "Aggiornato" : locale === "ja" ? "更新日" : "Updated",
  published: locale === "de" ? "Veröffentlicht" : locale === "hu" ? "Közzétéve" : locale === "fr" ? "Publié" : locale === "es" ? "Publicado" : locale === "it" ? "Pubblicato" : locale === "ja" ? "公開日" : "Published",
  imageCaption: locale === "de" ? "Visuelle Zusammenfassung des Artikels und seiner Website-Strategie." : locale === "hu" ? "A cikk és a weboldal-stratégia vizuális összefoglalója." : locale === "fr" ? "Résumé visuel de l'article et de sa stratégie de site web." : locale === "es" ? "Resumen visual del artículo y su estrategia web." : locale === "it" ? "Sintesi visiva dell'articolo e della strategia del sito." : locale === "ja" ? "記事とウェブサイト戦略の視覚的な要約。" : "Visual summary of the article and its website strategy.",
  next: locale === "de" ? "Nächster Artikel" : locale === "hu" ? "Következő cikk" : locale === "fr" ? "Article suivant" : locale === "es" ? "Artículo siguiente" : locale === "it" ? "Articolo successivo" : locale === "ja" ? "次の記事" : "Next article",
};
const authorSchema = { "@type": "Person", name: post.author, affiliation: { "@type": "Organization", name: "Websiteli", url: siteUrl.toString() } };
const imageSchema = {
  "@context": "https://schema.org",
  "@type": "ImageObject",
  url: imageUrl,
  contentUrl: imageUrl,
  caption: articleUi.imageCaption,
  width: 1536,
  height: 1024,
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  image: imageSchema,
  thumbnailUrl: imageUrl,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt,
  author: authorSchema,
  publisher: { "@type": "Organization", name: "Websiteli", logo: { "@type": "ImageObject", url: new URL("/assets/websiteli-logo.png", siteUrl).toString() } },
  mainEntityOfPage: canonicalUrl,
  articleSection: post.category,
  keywords: post.tags.join(", "),
  inLanguage: post.sourceLocale,
  about: post.tags.map((tag) => ({ "@type": "Thing", name: tag })),
  audience: { "@type": "Audience", audienceType: post.audience },
  abstract: post.summary.join(" "),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: content.nav.home, item: new URL(getLocalizedPath(locale), siteUrl).toString() },
    { "@type": "ListItem", position: 2, name: blogContent.eyebrow, item: new URL(getLocalizedPath(locale, "blog"), siteUrl).toString() },
    { "@type": "ListItem", position: 3, name: post.title, item: canonicalUrl },
  ],
};
const faqSchema = post.faqs?.length
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: post.faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: { "@type": "Answer", text: faq.answer },
      })),
    }
  : undefined;
const postAlternates = localeCodes.map((code) => ({ locale: code, href: `/${code}/blog/${post.slug}/` }));
const personSchema = { "@context": "https://schema.org", ...authorSchema };
---

<Layout
  title={`${post.title} - Websiteli`}
  description={post.description}
  canonicalPath={canonicalPath}
  lang={locale}
  locale={locale}
  page="blog"
  ogType="article"
  image={post.featuredImage}
  alternates={postAlternates}
  content={content}
  schema={[articleSchema, breadcrumbSchema, imageSchema, personSchema, ...(faqSchema ? [faqSchema] : [])]}
>
  <div class="reading-progress" data-reading-progress aria-hidden="true"></div>
  <main class="subpage article-page">
    <article>
      <header class="section-shell page-hero article-hero">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href={getLocalizedPath(locale)}>{content.nav.home}</a>
          <span>/</span>
          <a href={getLocalizedPath(locale, "blog")}>{blogContent.eyebrow}</a>
        </nav>
        <p class="eyebrow">{post.category}</p>
        <h1>{post.title}</h1>
        <p>{post.description}</p>
        <div class="blog-meta">
          <span>{post.readingTime}</span>
          <span>{articleUi.published}: <time datetime={post.publishedAt}>{post.publishedAt}</time></span>
          <span>{articleUi.updated}: <time datetime={post.updatedAt}>{post.updatedAt}</time></span>
        </div>
        <div class="article-tags" aria-label="Article tags">
          {post.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>
      <div class="section-shell article-layout">
        <aside class="article-sidebar">
          <nav class="toc" aria-label="Table of contents">
            <strong>{articleUi.contents}</strong>
            {post.headings.map((heading) => <a href={`#${getHeadingId(heading)}`} data-toc-link>{heading}</a>)}
          </nav>
          <ArticleCTA locale={locale} variant="sidebar" />
        </aside>
        <div class="article-content">
          <figure class="article-figure">
            <a href={post.featuredImage} target="_blank" rel="noopener noreferrer" aria-label="Open article image">
              <img class="article-image" src={post.featuredImage} alt={`${post.title} - ${post.category}`} width="1536" height="1024" loading="eager" />
            </a>
            <figcaption>{articleUi.imageCaption}</figcaption>
          </figure>
          <section class="article-ai-summary" aria-labelledby="article-summary">
            <h2 id="article-summary">{articleUi.summary}</h2>
            <ul>
              {post.summary.map((item) => <li>{item}</li>)}
            </ul>
          </section>
          <section class="article-key-takeaways" aria-labelledby="key-takeaways">
            <h2 id="key-takeaways">{articleUi.takeaways}</h2>
            <ul>
              {post.keyTakeaways.map((item) => <li>{item}</li>)}
            </ul>
          </section>
          <Fragment set:html={articleHtml} />
          <ArticleCTA locale={locale} variant="final" />
          <ArticleShare url={canonicalUrl} title={post.title} image={imageUrl} social={post.social} />
          {nextPost && (
            <nav class="article-nav" aria-label="Article navigation">
              <a href={`/${locale}/blog/${nextPost.slug}/`}><span>{articleUi.next}</span>{nextPost.title}</a>
            </nav>
          )}
          {post.references.length > 0 && (
            <section class="article-references" aria-label={articleUi.references}>
              <h2>{articleUi.references}</h2>
              <ul>
                {post.references.map((reference) => (
                  <li>
                    <a href={reference.href} target="_blank" rel="noopener noreferrer">
                      <span aria-hidden="true">↗</span>
                      <strong>{reference.title}</strong>
                      <small>{reference.publisher}</small>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>
      </div>
    </article>
  </main>
</Layout>

<script>
  const readingProgress = document.querySelector("[data-reading-progress]");
  const article = document.querySelector(".article-content");
  const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
  const tocTargets = tocLinks
    .map((link) => {
      if (!(link instanceof HTMLAnchorElement)) return null;
      const target = document.querySelector(decodeURIComponent(link.hash));
      return target instanceof HTMLElement ? { link, target } : null;
    })
    .filter(Boolean);

  function updateReadingProgress() {
    if (!(readingProgress instanceof HTMLElement) || !(article instanceof HTMLElement)) return;

    const articleTop = article.offsetTop;
    const articleHeight = Math.max(article.scrollHeight - window.innerHeight, 1);
    const progress = Math.min(Math.max((window.scrollY - articleTop) / articleHeight, 0), 1);
    readingProgress.style.transform = `scaleX(${progress})`;
  }

  function updateActiveToc() {
    let active;
    tocTargets.forEach((item) => {
      if (item.target.getBoundingClientRect().top < 150) active = item;
    });
    tocLinks.forEach((link) => link.removeAttribute("aria-current"));
    active?.link.setAttribute("aria-current", "true");
  }

  document.addEventListener("click", async (event) => {
    const button = event.target instanceof Element ? event.target.closest("[data-copy-code]") : null;
    if (!(button instanceof HTMLButtonElement)) return;
    const code = button.closest("[data-code-block]")?.querySelector("code")?.textContent ?? "";
    try {
      await navigator.clipboard.writeText(code);
      button.textContent = "Copied";
      window.setTimeout(() => (button.textContent = "Copy"), 1400);
    } catch {
      window.prompt("Copy code", code);
    }
  });

  updateReadingProgress();
  updateActiveToc();
  document.addEventListener("scroll", () => {
    updateReadingProgress();
    updateActiveToc();
  }, { passive: true });
  window.addEventListener("resize", updateReadingProgress);
</script>
