---
import { demoSlugs } from "../../../../content/demos";
import { localeCodes, type LocaleCode } from "../../../../content/locales";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) => demoSlugs.map((demo) => ({ params: { locale, demo } })));
}

const locale = Astro.params.locale as LocaleCode;
return Astro.redirect(`/${locale}/portfolio/#live-demos`);
---
