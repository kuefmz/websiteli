---
import PageSections from "../../../components/PageSections.astro";
import Layout from "../../../layouts/Layout.astro";
import {
  getAlternates,
  getLocaleContent,
  getLocalizedPath,
  legacyPageSlugs,
  legacyRedirects,
  localeCodes,
  pageNavKeys,
  pageSlugs,
  type LocaleCode,
  type PageSlug,
  type LegacyPageSlug,
} from "../../../content/locales";
import { getDemoPageContent } from "../../../content/demos";
import { getBlogIndexContent } from "../../../content/blog";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) => [...pageSlugs, ...legacyPageSlugs].map((page) => ({ params: { locale, page } })));
}

const locale = Astro.params.locale as LocaleCode;
const requestedPage = Astro.params.page as PageSlug | LegacyPageSlug;

if (requestedPage in legacyRedirects) {
  return Astro.redirect(getLocalizedPath(locale, requestedPage));
}

const page = requestedPage as PageSlug;
const content = getLocaleContent(locale);
const demoContent = getDemoPageContent(locale);
const blogContent = getBlogIndexContent(locale);
const label = content.nav[pageNavKeys[page]] ?? (page === "blog" ? blogContent.eyebrow : page);
const title =
  page === "portfolio"
    ? demoContent.seo.title
    : page === "blog"
      ? blogContent.seo.title
      : page === "services-pricing"
        ? `${content.nav.servicesPricing ?? "Services & Pricing"} - Websiteli`
        : `${label} - Websiteli`;
const description =
  page === "services-pricing"
    ? content.packagesIntro.text
    : page === "portfolio"
      ? demoContent.seo.description
      : page === "blog"
        ? blogContent.seo.description
        : page === "about"
          ? content.about.text
          : content.contact.text;
---

<Layout
  title={title}
  description={description}
  canonicalPath={getLocalizedPath(locale, page)}
  lang={locale}
  locale={locale}
  page={page}
  alternates={getAlternates(page)}
  content={content}
>
  <PageSections content={content} page={page} locale={locale} />
</Layout>
