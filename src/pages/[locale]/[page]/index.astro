---
import PageSections from "../../../components/PageSections.astro";
import Layout from "../../../layouts/Layout.astro";
import {
  getAlternates,
  getLocaleContent,
  getLocalizedPath,
  legacyPageSlugs,
  legacyRedirects,
  localeCodes,
  pageNavKeys,
  pageSlugs,
  type LocaleCode,
  type PageSlug,
  type LegacyPageSlug,
} from "../../../content/locales";
import { getDemoPageContent } from "../../../content/demos";
import { getBlogIndexContent } from "../../../content/blog";
import { getPartnerPageContent } from "../../../content/partners";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) => [...pageSlugs, ...legacyPageSlugs].map((page) => ({ params: { locale, page } })));
}

const locale = Astro.params.locale as LocaleCode;
const requestedPage = Astro.params.page as PageSlug | LegacyPageSlug;
const redirectTarget = requestedPage in legacyRedirects ? getLocalizedPath(locale, requestedPage) : "";

const page = requestedPage as PageSlug;
const content = getLocaleContent(locale);
const demoContent = getDemoPageContent(locale);
const blogContent = getBlogIndexContent(locale);
const partnerContent = getPartnerPageContent(locale);
const siteUrl = Astro.site ?? new URL("https://websiteli.ch");
const label = content.nav[pageNavKeys[page]] ?? (page === "blog" ? blogContent.eyebrow : page);
const title =
  page === "partners"
    ? partnerContent.seo.title
    : page === "portfolio"
    ? demoContent.seo.title
    : page === "blog"
      ? blogContent.seo.title
      : page === "services-pricing"
        ? `${content.nav.servicesPricing ?? "Services & Pricing"} - Websiteli`
        : `${label} - Websiteli`;
const description =
  page === "partners"
    ? partnerContent.seo.description
    : page === "services-pricing"
    ? content.packagesIntro.text
    : page === "portfolio"
      ? demoContent.seo.description
      : page === "blog"
        ? blogContent.seo.description
        : page === "about"
        ? content.about.text
        : content.contact.text;
const pageSchema =
  page === "partners"
    ? [
        {
          "@context": "https://schema.org",
          "@type": "Service",
          name: "White-label web development Switzerland",
          provider: {
            "@type": "Organization",
            name: "Websiteli",
            url: siteUrl.toString(),
          },
          areaServed: {
            "@type": "Country",
            name: "Switzerland",
          },
          audience: partnerContent.audiences.map((item) => ({
            "@type": "Audience",
            audienceType: item.title,
          })),
          serviceType: [
            "White-label websites",
            "Agency web development partner",
            "Website outsourcing Switzerland",
            "AI automation partner",
            "Marketing agency development partner",
            "Wedding website developer",
            "Event website developer",
          ],
          description: partnerContent.seo.description,
        },
        {
          "@context": "https://schema.org",
          "@type": "FAQPage",
          mainEntity: partnerContent.faqs.map((item) => ({
            "@type": "Question",
            name: item.question,
            acceptedAnswer: {
              "@type": "Answer",
              text: item.answer,
            },
          })),
        },
      ]
    : [];
---

{
  redirectTarget ? (
    <html lang={locale}>
      <head>
        <meta charset="utf-8" />
        <link rel="canonical" href={redirectTarget} />
        <script is:inline define:vars={{ redirectTarget }}>
          try {
            window.sessionStorage?.setItem("websiteli_redirect_context", JSON.stringify({
              landingPage: window.location.href,
              referrer: document.referrer || "",
            }));
          } catch {}
          const target = new URL(redirectTarget, window.location.origin);
          target.search = window.location.search;
          target.hash = window.location.hash;
          window.location.replace(target.toString());
        </script>
        <title>Websiteli</title>
      </head>
      <body>
        <a href={redirectTarget}>Continue to Websiteli</a>
      </body>
    </html>
  ) : (
    <Layout
      title={title}
      description={description}
      canonicalPath={getLocalizedPath(locale, page)}
      lang={locale}
      locale={locale}
      page={page}
      alternates={getAlternates(page)}
      content={content}
      schema={pageSchema}
      includeDefaultFaq={page !== "partners"}
    >
      <PageSections content={content} page={page} locale={locale} />
    </Layout>
  )
}
