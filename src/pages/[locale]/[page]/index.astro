---
import PageSections from "../../../components/PageSections.astro";
import Layout from "../../../layouts/Layout.astro";
import {
  getAlternates,
  getLocaleContent,
  getLocalizedPath,
  legacyPageSlugs,
  legacyRedirects,
  localeCodes,
  pageNavKeys,
  pageSlugs,
  type LocaleCode,
  type PageSlug,
  type LegacyPageSlug,
} from "../../../content/locales";
import { getDemoPageContent } from "../../../content/demos";
import { getBlogIndexContent } from "../../../content/blog";

export function getStaticPaths() {
  return localeCodes.flatMap((locale) => [...pageSlugs, ...legacyPageSlugs].map((page) => ({ params: { locale, page } })));
}

const locale = Astro.params.locale as LocaleCode;
const requestedPage = Astro.params.page as PageSlug | LegacyPageSlug;
const redirectTarget = requestedPage in legacyRedirects ? getLocalizedPath(locale, requestedPage) : "";

const page = requestedPage as PageSlug;
const content = getLocaleContent(locale);
const demoContent = getDemoPageContent(locale);
const blogContent = getBlogIndexContent(locale);
const label = content.nav[pageNavKeys[page]] ?? (page === "blog" ? blogContent.eyebrow : page);
const title =
  page === "portfolio"
    ? demoContent.seo.title
    : page === "blog"
      ? blogContent.seo.title
      : page === "services-pricing"
        ? `${content.nav.servicesPricing ?? "Services & Pricing"} - Websiteli`
        : `${label} - Websiteli`;
const description =
  page === "services-pricing"
    ? content.packagesIntro.text
    : page === "portfolio"
      ? demoContent.seo.description
      : page === "blog"
        ? blogContent.seo.description
        : page === "about"
          ? content.about.text
          : content.contact.text;
---

{
  redirectTarget ? (
    <html lang={locale}>
      <head>
        <meta charset="utf-8" />
        <link rel="canonical" href={redirectTarget} />
        <script is:inline define:vars={{ redirectTarget }}>
          try {
            window.sessionStorage?.setItem("websiteli_redirect_context", JSON.stringify({
              landingPage: window.location.href,
              referrer: document.referrer || "",
            }));
          } catch {}
          const target = new URL(redirectTarget, window.location.origin);
          target.search = window.location.search;
          target.hash = window.location.hash;
          window.location.replace(target.toString());
        </script>
        <title>Websiteli</title>
      </head>
      <body>
        <a href={redirectTarget}>Continue to Websiteli</a>
      </body>
    </html>
  ) : (
    <Layout
      title={title}
      description={description}
      canonicalPath={getLocalizedPath(locale, page)}
      lang={locale}
      locale={locale}
      page={page}
      alternates={getAlternates(page)}
      content={content}
    >
      <PageSections content={content} page={page} locale={locale} />
    </Layout>
  )
}
