---
import Layout from "../../layouts/Layout.astro";
import { getLocaleContent } from "../../content/locales";
import { getOnboardingSettings } from "../../config/onboarding";

const content = getLocaleContent("en");
const settings = getOnboardingSettings();
const title = "Websiteli Client Onboarding";
const description = "Client onboarding steps for paid Websiteli projects: questionnaire, strategy call, build, review and launch.";
---

<Layout title={`${title} - Websiteli`} description={description} canonicalPath="/onboarding/" lang="en" locale="en" page="onboarding" content={content} robots="noindex, follow">
  <main class="subpage onboarding-page">
    <section class="section-shell page-hero">
      <p class="eyebrow">Client onboarding</p>
      <h1>Start your paid Websiteli project.</h1>
      <p>Use this page after your manual invoice has been paid and confirmed. Complete the questionnaire first, then book the strategy call so we can plan the build clearly.</p>
      <div class="hero-actions">
        {
          settings.hasOnboardingFormUrl ? (
            <a class="button primary" href={settings.onboardingFormUrl} target="_blank" rel="noopener noreferrer">Open questionnaire</a>
          ) : (
            <a class="button primary" href={settings.contactFallbackPath}>Request questionnaire link</a>
          )
        }
        {
          settings.hasCalendlyUrl ? (
            <a class="button secondary" href={settings.calendlyUrl} target="_blank" rel="noopener noreferrer">Book strategy call</a>
          ) : (
            <a class="button secondary" href={settings.contactFallbackPath}>Request booking link</a>
          )
        }
      </div>
    </section>

    <section class="section-shell onboarding-flow" aria-label="Onboarding steps">
      <article>
        <span>01</span>
        <h2>Questionnaire</h2>
        <p>Share business details, services, target audience, examples, assets and practical constraints.</p>
      </article>
      <article>
        <span>02</span>
        <h2>Strategy call</h2>
        <p>We clarify priorities, pages, content gaps, integrations, launch timing and success criteria.</p>
      </article>
      <article>
        <span>03</span>
        <h2>Build and review</h2>
        <p>Websiteli creates the website, SEO foundations, forms and practical AI-assisted improvements where useful.</p>
      </article>
      <article>
        <span>04</span>
        <h2>Launch</h2>
        <p>After review and final checks, the website goes live with handover and maintenance recommendations.</p>
      </article>
    </section>

    <section class="section-shell section-block compact-top">
      <div class="detail-layout onboarding-detail-layout">
        <article class="detail-panel">
          <h2>Before you start</h2>
          <ul class="feature-list">
            <li>Invoice payment should already be confirmed.</li>
            <li>Prepare logo files, brand colors, photos and existing website links if available.</li>
            <li>Collect service descriptions, pricing notes, contact details and legal page requirements.</li>
          </ul>
        </article>
        <article class="detail-panel">
          <h2>Graceful fallback</h2>
          <p>If a questionnaire or Calendly link is not configured yet, use the contact page. We will send the missing link manually.</p>
          <a class="button secondary" href={settings.contactFallbackPath}>Contact Websiteli</a>
        </article>
      </div>
    </section>
  </main>
</Layout>
