---
import Layout from "../../../layouts/Layout.astro";
import { getLocaleContent } from "../../../content/locales";
import { getOnboardingSettings } from "../../../config/onboarding";

const content = getLocaleContent("en");
const settings = getOnboardingSettings();
const title = "Reservation Request Prepared";
const description = "Your Websiteli reservation request is ready. We review project details, send a manual invoice by email, and begin onboarding after payment.";
---

<Layout title={`${title} - Websiteli`} description={description} canonicalPath="/reserve/thank-you/" lang="en" locale="en" page="reserve-thank-you" content={content} robots="noindex, follow">
  <main class="subpage reserve-page">
    <section class="section-shell page-hero">
      <p class="eyebrow">Reservation next steps</p>
      <h1>Thank you. Your reservation was sent.</h1>
      <p>We received your project details and sent a confirmation email to the address you provided. Websiteli will review the request, reply with the manual invoice, and start onboarding after bank transfer payment is confirmed.</p>
      <div class="hero-actions">
        <a class="button primary" href={settings.contactFallbackPath}>Contact Websiteli</a>
        <a class="button secondary" href="/en/services-pricing/">Back to packages</a>
      </div>
    </section>

    <section class="section-shell onboarding-flow" aria-label="What happens next">
      <article>
        <span>01</span>
        <h2>We review the request</h2>
        <p>We check the project type, business context, language preference and scope.</p>
      </article>
      <article>
        <span>02</span>
        <h2>You receive a manual invoice</h2>
        <p>The invoice is sent by email. No Stripe, PayPal, TWINT or payment gateway is used on this website.</p>
      </article>
      <article>
        <span>03</span>
        <h2>Onboarding starts after payment</h2>
        <p>After payment is confirmed, we send the questionnaire and Calendly strategy call link.</p>
      </article>
    </section>

    <section class="section-shell section-block compact-top">
      <div class="large-note">
        <strong>Manual flow</strong>
        <span>This page does not confirm payment. Your reservation is stored in the private Websiteli sheet, then the invoice and onboarding steps are handled manually.</span>
      </div>
    </section>
  </main>
</Layout>
