---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Privacy Policy | Websiteli"
  description="Privacy information for Websiteli visitors and contact form submissions."
  canonicalPath="/privacy/"
>
  <main class="simple-page section-shell">
    <p class="eyebrow">Privacy Policy</p>
    <h1>Privacy Policy</h1>
    <p>
      We only collect the information you send through the contact form so we can reply to your request.
      This can include your name, email address, phone number, company, and message.
    </p>
    <p>
      Website analytics may be used to understand how visitors use the site. This helps us improve the website.
      We do not sell personal information.
    </p>
    <p>
      For privacy questions, contact <a href="mailto:hello@websiteli.ch">hello@websiteli.ch</a>.
    </p>
  </main>
</Layout>
