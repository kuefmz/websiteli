---
import { getPackageLabels } from "../config/packageLabels";
import { packageKeyByName } from "../config/pricing";

interface Props {
  content?: any;
}

const { content } = Astro.props;
const contact = content?.contact ?? {
  eyebrow: "Contact",
  title: "Tell us what you want to build.",
  text: "We will reply with a simple suggestion and clear next steps.",
  button: "Send request",
};
const packages = content?.packages ?? [
  { name: "Digital Foundation" },
  { name: "Growth Setup" },
  { name: "AI/Data Upgrade" },
];
const packageOptions = [...packages, { name: "Digital Audit" }].reduce((options, item) => {
  const key = packageKeyByName[item.name] ?? item.name;
  if (options.some((option) => option.key === key)) return options;

  return [...options, { name: item.name, key }];
}, [] as Array<{ name: string; key: string }>);
const localizedPackageNames = getPackageLabels(content?.locale ?? "en");
const privacyConsentCopy: Record<string, { label: string; link: string; validation: string }> = {
  en: {
    label: "I have read and accept the",
    link: "Privacy Policy",
    validation: "Please accept the privacy policy before sending.",
  },
  de: {
    label: "Ich habe gelesen und akzeptiere die",
    link: "Datenschutzerklärung",
    validation: "Bitte akzeptieren Sie die Datenschutzerklärung vor dem Absenden.",
  },
  hu: {
    label: "Elolvastam és elfogadom az",
    link: "adatvédelmi tájékoztatót",
    validation: "Kérjük, küldés előtt fogadd el az adatvédelmi tájékoztatót.",
  },
  pl: {
    label: "Przeczytałem/am i akceptuję",
    link: "politykę prywatności",
    validation: "Zaakceptuj politykę prywatności przed wysłaniem.",
  },
  es: {
    label: "He leído y acepto la",
    link: "política de privacidad",
    validation: "Acepta la política de privacidad antes de enviar.",
  },
  fr: {
    label: "J'ai lu et j'accepte la",
    link: "politique de confidentialité",
    validation: "Veuillez accepter la politique de confidentialité avant l'envoi.",
  },
  it: {
    label: "Ho letto e accetto la",
    link: "privacy policy",
    validation: "Accetta la privacy policy prima di inviare.",
  },
  cz: {
    label: "Přečetl/a jsem si a přijímám",
    link: "zásady ochrany osobních údajů",
    validation: "Před odesláním přijměte zásady ochrany osobních údajů.",
  },
  sk: {
    label: "Prečítal/a som si a prijímam",
    link: "zásady ochrany osobných údajov",
    validation: "Pred odoslaním prijmite zásady ochrany osobných údajov.",
  },
  pt: {
    label: "Li e aceito a",
    link: "política de privacidade",
    validation: "Aceite a política de privacidade antes de enviar.",
  },
  da: {
    label: "Jeg har læst og accepterer",
    link: "privatlivspolitikken",
    validation: "Accepter privatlivspolitikken før du sender.",
  },
  nl: {
    label: "Ik heb gelezen en accepteer het",
    link: "privacybeleid",
    validation: "Accepteer het privacybeleid voordat je verzendt.",
  },
  ja: {
    label: "確認し、同意します:",
    link: "プライバシーポリシー",
    validation: "送信前にプライバシーポリシーに同意してください。",
  },
};
const privacyUi = privacyConsentCopy[content?.locale ?? "en"] ?? privacyConsentCopy.en;
const privacyPolicyVersion = "2026-06-24";
const formUi = content?.ui?.form ?? {
  website: "Website",
  name: "Name",
  email: "Email",
  phone: "Phone",
  company: "Company",
  project: "What do you need?",
  custom: "Something custom",
  message: "Message",
  messagePlaceholder: "Tell us about your business and what you would like to improve.",
  thankYou: "Thank you! We received your message and will get back to you soon.",
  validation: "Please fill in your name, email, and message.",
  disconnected: "The form is not connected yet. Please email us directly.",
  sending: "Sending...",
  error: "Something went wrong. Please email us directly.",
};
---

<section class="cta section-shell" id="contact">
  <div class="cta-panel">
    <div>
      <p class="eyebrow">{contact.eyebrow}</p>
      <h2>{contact.title}</h2>
      <p>{contact.text}</p>
    </div>
    <form
      class="contact-form"
      action="#contact"
      method="post"
      enctype="text/plain"
      data-lead-form
      novalidate
    >
      <input name="source" type="hidden" value="websiteli.ch" />
      <input name="locale" type="hidden" value={content?.locale ?? "en"} data-pricing-field="locale" />
      <input name="country" type="hidden" data-pricing-field="country" />
      <input name="pricingMarket" type="hidden" data-pricing-field="pricingMarket" />
      <input name="currency" type="hidden" data-pricing-field="currency" />
      <input name="packageKey" type="hidden" data-pricing-field="packageKey" />
      <input name="relatedDemo" type="hidden" data-pricing-field="relatedDemo" />
      <input name="relatedProject" type="hidden" data-pricing-field="relatedProject" />
      <input name="sourcePage" type="hidden" data-pricing-field="sourcePage" />
      <input name="inquiryIntent" type="hidden" data-pricing-field="inquiryIntent" />
      <input name="priceShown" type="hidden" data-pricing-field="priceShown" />
      <input name="sourcePath" type="hidden" data-pricing-field="sourcePath" />
      <input name="currentUrl" type="hidden" data-pricing-field="currentUrl" />
      <input name="referrer" type="hidden" data-pricing-field="referrer" />
      <input name="timestamp" type="hidden" data-pricing-field="timestamp" />
      <input name="userAgent" type="hidden" data-pricing-field="userAgent" />
      <input name="utm_source" type="hidden" data-pricing-field="utm" data-utm-key="utm_source" />
      <input name="utm_medium" type="hidden" data-pricing-field="utm" data-utm-key="utm_medium" />
      <input name="utm_campaign" type="hidden" data-pricing-field="utm" data-utm-key="utm_campaign" />
      <input name="utm_term" type="hidden" data-pricing-field="utm" data-utm-key="utm_term" />
      <input name="utm_content" type="hidden" data-pricing-field="utm" data-utm-key="utm_content" />
      <input name="utm_id" type="hidden" data-pricing-field="utm" data-utm-key="utm_id" />
      <input name="privacyPolicyVersion" type="hidden" value={privacyPolicyVersion} />
      <label class="website-field" aria-hidden="true">
        {formUi.website}
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
      <label>
        {formUi.name}
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        {formUi.email}
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        {formUi.phone}
        <input name="phone" type="tel" autocomplete="tel" />
      </label>
      <label>
        {formUi.company}
        <input name="company" autocomplete="organization" />
      </label>
      <label>
        {formUi.project}
        <select name="project" data-package-select>
          {packageOptions.map((item) => <option value={item.key}>{localizedPackageNames[item.key] ?? item.name}</option>)}
          <option value="custom">{formUi.custom}</option>
        </select>
      </label>
      <label>
        {formUi.message}
        <textarea name="message" rows="4" required placeholder={formUi.messagePlaceholder}></textarea>
      </label>
      <label class="privacy-consent">
        <input name="privacyPolicyAccepted" type="checkbox" value="yes" required data-privacy-consent />
        <span>
          {privacyUi.label} <a href="/privacy/" target="_blank" rel="noopener">{privacyUi.link}</a>.
        </span>
      </label>
      <button class="button primary" type="submit">{contact.button}</button>
      <p class="form-status" data-form-status aria-live="polite"></p>
    </form>
  </div>
</section>

<script define:vars={{ formUi, privacyUi }}>
  const form = document.querySelector("[data-lead-form]");
  const status = document.querySelector("[data-form-status]");
  let formStarted = false;

  function getFormString(formData, key) {
    return String(formData.get(key) || "").trim();
  }

  function getUtm(formData) {
    const attribution = window.websiteliGetAttribution?.() || {};

    return {
      source: attribution.utm_source || getFormString(formData, "utm_source"),
      medium: attribution.utm_medium || getFormString(formData, "utm_medium"),
      campaign: attribution.utm_campaign || getFormString(formData, "utm_campaign"),
      term: attribution.utm_term || getFormString(formData, "utm_term"),
      content: attribution.utm_content || getFormString(formData, "utm_content"),
      id: attribution.utm_id || getFormString(formData, "utm_id"),
      attribution,
    };
  }

  form?.addEventListener("input", () => {
    if (formStarted) return;
    formStarted = true;
    window.websiteliUpdateInquiryFields?.();
    const formData = new FormData(form);

    window.trackWebsiteliEvent?.("contact_form_start", {
      package_key: getFormString(formData, "packageKey") || getFormString(formData, "project"),
      locale: getFormString(formData, "locale") || document.documentElement.lang,
      country: getFormString(formData, "country"),
      pricing_market: getFormString(formData, "pricingMarket"),
      currency: getFormString(formData, "currency"),
      price_shown: getFormString(formData, "priceShown"),
      source_path: getFormString(formData, "sourcePath") || window.location.pathname,
      source_page: getFormString(formData, "sourcePage") || window.location.pathname,
      related_demo: getFormString(formData, "relatedDemo"),
      related_project: getFormString(formData, "relatedProject"),
      inquiry_intent: getFormString(formData, "inquiryIntent"),
    });
  });

  form?.addEventListener("submit", async (event) => {
    window.websiteliUpdateInquiryFields?.();
    const submitButton = form.querySelector("button[type='submit']");
    const formData = new FormData(form);
    const name = getFormString(formData, "name");
    const email = getFormString(formData, "email");
    const message = getFormString(formData, "message");
    const honeypot = getFormString(formData, "website");
    const privacyAccepted = getFormString(formData, "privacyPolicyAccepted") === "yes";

    if (honeypot) {
      event.preventDefault();
      form.reset();
      if (status) status.textContent = formUi.thankYou;
      return;
    }

    if (!form.checkValidity() || !name || !email || !message || !privacyAccepted) {
      event.preventDefault();
      form.reportValidity();
      if (status) status.textContent = privacyAccepted ? formUi.validation : privacyUi.validation;
      return;
    }

    event.preventDefault();

    const detectedCountry = getFormString(formData, "country") || window.websiteliPricing?.country || "";
    const detectedCurrency = getFormString(formData, "currency") || window.websiteliPricing?.currency || "";
    const detectedMarket = getFormString(formData, "pricingMarket") || window.websiteliPricing?.pricingMarket || "";
    const need = getFormString(formData, "project");
    const utm = getUtm(formData);
    const payload = {
      type: "form",
      name,
      email,
      phone: getFormString(formData, "phone"),
      company: getFormString(formData, "company"),
      need,
      message,
      metadata: {
        language: document.documentElement.lang || getFormString(formData, "locale"),
        country: detectedCountry,
        currency: detectedCurrency,
        market: detectedMarket,
        pageUrl: window.location.href,
        referrer: document.referrer,
        userAgent: navigator.userAgent,
        utm_source: utm.source,
        utm_medium: utm.medium,
        utm_campaign: utm.campaign,
        utm_term: utm.term,
        utm_content: utm.content,
        utm_id: utm.id,
        gclid: utm.attribution.gclid || "",
        gbraid: utm.attribution.gbraid || "",
        wbraid: utm.attribution.wbraid || "",
        fbclid: utm.attribution.fbclid || "",
        msclkid: utm.attribution.msclkid || "",
        landingPage: utm.attribution.landingPage || "",
        firstSeenAt: utm.attribution.firstSeenAt || "",
        first_utm_source: utm.attribution.first_utm_source || "",
        first_utm_medium: utm.attribution.first_utm_medium || "",
        first_utm_campaign: utm.attribution.first_utm_campaign || "",
        first_gclid: utm.attribution.first_gclid || "",
        first_fbclid: utm.attribution.first_fbclid || "",
        source: getFormString(formData, "source") || "websiteli.ch",
        packageKey: getFormString(formData, "packageKey") || need,
        relatedDemo: getFormString(formData, "relatedDemo"),
        relatedProject: getFormString(formData, "relatedProject"),
        sourcePage: getFormString(formData, "sourcePage") || window.location.pathname,
        inquiryIntent: getFormString(formData, "inquiryIntent"),
        priceShown: getFormString(formData, "priceShown"),
        sourcePath: getFormString(formData, "sourcePath") || window.location.pathname,
        privacyPolicyAccepted: privacyAccepted,
        privacyPolicyVersion: getFormString(formData, "privacyPolicyVersion"),
        privacyPolicyUrl: `${window.location.origin}/privacy/`,
        timestamp: getFormString(formData, "timestamp") || new Date().toISOString(),
      },
    };

    submitButton?.setAttribute("disabled", "true");
    if (status) status.textContent = formUi.sending;

    try {
      await fetch("https://script.google.com/macros/s/AKfycbxcU1PnJv0YFT7NFI_CnD71NbRl8mAjSljBbZjCqqCXt96bw1lEUlGhbel1-oBm4n-k/exec", {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "text/plain;charset=utf-8",
        },
        body: JSON.stringify(payload),
      });

      form.reset();
      window.trackWebsiteliEvent?.("contact_form_submit", {
        event_category: "lead",
        event_label: "Contact form",
        package_key: payload.metadata.packageKey,
        locale: payload.metadata.language,
        country: payload.metadata.country,
        pricing_market: payload.metadata.market,
        currency: payload.metadata.currency,
        price_shown: payload.metadata.priceShown,
        source_path: payload.metadata.sourcePath,
        source_page: payload.metadata.sourcePage,
        related_demo: payload.metadata.relatedDemo,
        related_project: payload.metadata.relatedProject,
        inquiry_intent: payload.metadata.inquiryIntent,
        utm_source: payload.metadata.utm_source,
        utm_medium: payload.metadata.utm_medium,
        utm_campaign: payload.metadata.utm_campaign,
        utm_term: payload.metadata.utm_term,
        utm_content: payload.metadata.utm_content,
        utm_id: payload.metadata.utm_id,
        privacy_policy_accepted: payload.metadata.privacyPolicyAccepted ? "yes" : "no",
        privacy_policy_version: payload.metadata.privacyPolicyVersion,
      });
      if (status) status.textContent = formUi.thankYou;
    } catch (error) {
      if (status) status.textContent = formUi.error;
      console.error(error);
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>
