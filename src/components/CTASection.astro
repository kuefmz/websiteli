<section class="cta section-shell" id="contact">
  <div class="cta-panel">
    <div>
      <p class="eyebrow">Contact</p>
      <h2>Tell us what you want to build.</h2>
      <p>We will reply with a simple suggestion and clear next steps.</p>
    </div>
    <form
      class="contact-form"
      action="/api/contact"
      method="post"
      enctype="text/plain"
      data-lead-form
      novalidate
    >
      <input name="source" type="hidden" value="websiteli.ch" />
      <label class="website-field" aria-hidden="true">
        Website
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
      <label>
        Name
        <input name="name" autocomplete="name" required />
      </label>
      <label>
        Email
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <label>
        Phone
        <input name="phone" type="tel" autocomplete="tel" />
      </label>
      <label>
        Company
        <input name="company" autocomplete="organization" />
      </label>
      <label>
        What do you need?
        <select name="project">
          <option value="landingPage">Starter Page</option>
          <option value="businessWebsite">Business Website</option>
          <option value="premiumWebsite">Larger Website</option>
          <option value="maintenanceMonthly">Website Care</option>
          <option value="custom">Smart tools or automation</option>
          <option value="custom">Something custom</option>
        </select>
      </label>
      <label>
        Message
        <textarea name="message" rows="4" required placeholder="Tell us about your business and what you would like to improve."></textarea>
      </label>
      <button class="button primary" type="submit">Send request</button>
      <p class="form-status" data-form-status aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector("[data-lead-form]");
  const status = document.querySelector("[data-form-status]");

  form?.addEventListener("submit", async (event) => {
    const submitButton = form.querySelector("button[type='submit']");
    const formData = new FormData(form);
    const name = String(formData.get("name") || "").trim();
    const email = String(formData.get("email") || "").trim();
    const message = String(formData.get("message") || "").trim();
    const honeypot = String(formData.get("website") || "").trim();

    if (honeypot) {
      event.preventDefault();
      form.reset();
      if (status) status.textContent = "Thank you! We received your message and will get back to you soon.";
      return;
    }

    if (!form.checkValidity() || !name || !email || !message) {
      event.preventDefault();
      form.reportValidity();
      if (status) status.textContent = "Please fill in your name, email, and message.";
      return;
    }

    event.preventDefault();

    const payload = {
      name,
      email,
      phone: String(formData.get("phone") || "").trim(),
      company: String(formData.get("company") || "").trim(),
      project: String(formData.get("project") || "").trim(),
      message,
      source: String(formData.get("source") || "websiteli.ch"),
      website: honeypot,
    };

    submitButton?.setAttribute("disabled", "true");
    if (status) status.textContent = "Sending...";

    try {
      const contactUrl = new URL("/api/contact", window.location.origin);
      const market = new URLSearchParams(window.location.search).get("market");

      if (market) {
        contactUrl.searchParams.set("market", market);
      }

      const response = await fetch(contactUrl, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error("Contact form request failed");
      }

      form.reset();
      window.trackWebsiteliEvent?.("contact_form_submission", {
        event_category: "lead",
        event_label: "Contact form",
      });
      if (status) status.textContent = "Thank you! We received your message and will get back to you soon.";
    } catch (error) {
      if (status) status.textContent = "Something went wrong. Please email us directly.";
      console.error(error);
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>
