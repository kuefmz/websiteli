---

<footer class="site-footer">
  <div class="footer-main">
    <a class="brand" href={`/${locale}/`} aria-label="websiteli.ch home">
      <span class="brand-mark">w</span>
      <span>Websiteli</span>
    </a>
    <p>{content?.intro ?? "Swiss-based websites, automation and AI tools for small businesses."}</p>
  </div>

  <div class="footer-links" aria-label="Footer links">
    <div>
      <h2>{footerUi.contact}</h2>
      <a href="mailto:jenifer.ciuciu-kiss@websiteli.ch" data-track-event="email_click" data-track-label="Footer email">jenifer.ciuciu-kiss@websiteli.ch</a>
      <a
        class="whatsapp-link"
        href={whatsappUrl}
        target="_blank"
        data-track-event="whatsapp_click"
        data-track-label="Footer WhatsApp"
        rel="noopener"
        aria-label={`WhatsApp ${whatsappNumber}`}
      >
        <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
          <path d="M16 3.2A12.7 12.7 0 0 0 5.1 22.5L3.8 29l6.7-1.2A12.7 12.7 0 1 0 16 3.2Zm0 2.3a10.4 10.4 0 0 1 8.8 15.9 10.4 10.4 0 0 1-13.9 4l-.4-.2-3.8.7.7-3.7-.2-.4A10.4 10.4 0 0 1 16 5.5Zm-4.3 5.1c-.3 0-.7.1-1 .5-.4.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4.1 6.4 5.5 3.2 1.3 3.8 1 4.5.9.7-.1 2.2-.9 2.5-1.8.3-.9.3-1.6.2-1.8-.1-.2-.3-.3-.7-.5l-2.3-1.1c-.3-.1-.6-.2-.8.2-.2.3-.9 1.1-1.1 1.4-.2.2-.4.3-.8.1-.4-.2-1.5-.5-2.8-1.7-1-1-1.8-2.1-2-2.5-.2-.3 0-.5.2-.7l.5-.6c.2-.2.2-.3.4-.6.1-.2.1-.4 0-.6l-1.1-2.7c-.3-.8-.6-.7-.8-.7h-.7Z" />
        </svg>
        <span>WhatsApp {whatsappNumber}</span>
      </a>
    </div>
    <div>
      <h2>{footerUi.pages}</h2>
      <a href={`/${locale}/services/`}>{nav.services}</a>
      <a href={`/${locale}/packages/`}>{nav.packages}</a>
      <a href={`/${locale}/demos/`}>{nav.demos}</a>
      <a href={`/${locale}/example-projects/`}>{exampleProjectsLabel}</a>
      <a href={`/${locale}/about/`}>{nav.about}</a>
    </div>
    <div>
      <h2>{footerUi.legal}</h2>
      <a href="/privacy/">{legalLinks.privacy}</a>
      <a href="/impressum/">{legalLinks.impressum}</a>
    </div>
    <div>
      <h2>{footerUi.social}</h2>
      <span>{footerUi.socialSoon}</span>
    </div>
    <div class="footer-newsletter">
      <h2>{newsletterUi.title}</h2>
      <p>{newsletterUi.text}</p>
      <form data-newsletter-form novalidate>
        <label class="website-field" aria-hidden="true">
          Website
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <label>
          <span>{newsletterUi.email}</span>
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label class="newsletter-consent">
          <input name="privacyPolicyAccepted" type="checkbox" value="yes" required />
          <span>{newsletterUi.consent} <a href="/privacy/" target="_blank" rel="noopener">{legalLinks.privacy}</a></span>
        </label>
        <button class="button secondary" type="submit">{newsletterUi.button}</button>
        <p class="newsletter-status" data-newsletter-status aria-live="polite"></p>
      </form>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {currentYear} Websiteli. {footerUi.rights}</p>
  </div>
</footer>

<script define:vars={{ newsletterUi }}>
  const newsletterForm = document.querySelector("[data-newsletter-form]");
  const newsletterStatus = document.querySelector("[data-newsletter-status]");

  function getNewsletterString(formData, key) {
    return String(formData.get(key) || "").trim();
  }

  newsletterForm?.addEventListener("submit", async (event) => {
    event.preventDefault();
    window.websiteliUpdateInquiryFields?.();

    const formData = new FormData(newsletterForm);
    const email = getNewsletterString(formData, "email");
    const honeypot = getNewsletterString(formData, "website");
    const privacyAccepted = getNewsletterString(formData, "privacyPolicyAccepted") === "yes";
    const submitButton = newsletterForm.querySelector("button[type='submit']");

    if (honeypot) {
      newsletterForm.reset();
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.success;
      return;
    }

    if (!newsletterForm.checkValidity() || !email || !privacyAccepted) {
      newsletterForm.reportValidity();
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.validation;
      return;
    }

    const searchParams = new URLSearchParams(location.search);
    const detectedCountry = window.websiteliPricing?.country || "";
    const detectedCurrency = window.websiteliPricing?.currency || "";
    const detectedMarket = window.websiteliPricing?.pricingMarket || "";
    const payload = {
      type: "newsletter",
      email,
      metadata: {
        language: document.documentElement.lang,
        country: detectedCountry,
        currency: detectedCurrency,
        market: detectedMarket,
        pageUrl: window.location.href,
        referrer: document.referrer,
        userAgent: navigator.userAgent,
        utm_source: searchParams.get("utm_source"),
        utm_medium: searchParams.get("utm_medium"),
        utm_campaign: searchParams.get("utm_campaign"),
        privacyPolicyAccepted: privacyAccepted,
        privacyPolicyVersion: "2026-06-24",
        privacyPolicyUrl: `${window.location.origin}/privacy/`,
        timestamp: new Date().toISOString(),
      },
    };

    submitButton?.setAttribute("disabled", "true");
    if (newsletterStatus) newsletterStatus.textContent = newsletterUi.sending;

    try {
      await fetch("https://script.google.com/macros/s/AKfycbxcU1PnJv0YFT7NFI_CnD71NbRl8mAjSljBbZjCqqCXt96bw1lEUlGhbel1-oBm4n-k/exec", {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "text/plain;charset=utf-8",
        },
        body: JSON.stringify(payload),
      });

      newsletterForm.reset();
      window.trackWebsiteliEvent?.("newsletter_subscribe", {
        event_category: "lead",
        event_label: "Newsletter",
        locale: payload.metadata.language,
        country: payload.metadata.country,
        pricing_market: payload.metadata.market,
        currency: payload.metadata.currency,
        source_path: window.location.pathname,
        privacy_policy_accepted: "yes",
      });
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.success;
    } catch (error) {
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.error;
      console.error(error);
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  });
</script>
