---

<footer class="site-footer">
  <div class="footer-main">
    <a class="brand" href={`/${locale}/`} aria-label="websiteli.ch home">
      <span class="brand-mark"><img src="/assets/websiteli-logo.png" alt="" width="36" height="36" /></span>
      <span>Websiteli</span>
    </a>
    <p>{content?.intro ?? "Swiss-based websites, automation and AI tools for small businesses."}</p>
  </div>

  <div class="footer-links" aria-label="Footer links">
    <div>
      <h2>{footerUi.contact}</h2>
      <a href="mailto:info@websiteli.ch" data-track-event="email_click" data-track-label="Footer email">info@websiteli.ch</a>
      <a
        class="whatsapp-link"
        href={whatsappUrl}
        target="_blank"
        data-track-event="whatsapp_click"
        data-track-label="Footer WhatsApp"
        rel="noopener"
        aria-label={`${whatsappNumber}`}
      >
        <svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
          <path d="M16 3.2A12.7 12.7 0 0 0 5.1 22.5L3.8 29l6.7-1.2A12.7 12.7 0 1 0 16 3.2Zm0 2.3a10.4 10.4 0 0 1 8.8 15.9 10.4 10.4 0 0 1-13.9 4l-.4-.2-3.8.7.7-3.7-.2-.4A10.4 10.4 0 0 1 16 5.5Zm-4.3 5.1c-.3 0-.7.1-1 .5-.4.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4.1 6.4 5.5 3.2 1.3 3.8 1 4.5.9.7-.1 2.2-.9 2.5-1.8.3-.9.3-1.6.2-1.8-.1-.2-.3-.3-.7-.5l-2.3-1.1c-.3-.1-.6-.2-.8.2-.2.3-.9 1.1-1.1 1.4-.2.2-.4.3-.8.1-.4-.2-1.5-.5-2.8-1.7-1-1-1.8-2.1-2-2.5-.2-.3 0-.5.2-.7l.5-.6c.2-.2.2-.3.4-.6.1-.2.1-.4 0-.6l-1.1-2.7c-.3-.8-.6-.7-.8-.7h-.7Z" />
        </svg>
        <span>{whatsappNumber}</span>
      </a>
    </div>
    <div>
      <h2>{footerUi.pages}</h2>
      <a href={`/${locale}/services-pricing/`}>{nav.servicesPricing ?? "Services & Pricing"}</a>
      <a href={`/${locale}/portfolio/`}>{nav.portfolio ?? "Portfolio"}</a>
      <a href={`/${locale}/partners/`}>{nav.partners ?? "Partners"}</a>
      <a href={`/${locale}/blog/`}>{nav.blog ?? "Blog"}</a>
      <a href={`/${locale}/about/`}>{nav.about}</a>
      {footerServices.map((service) => <a href={`/${locale}/services/${service.slug}/`}>{service.shortTitle}</a>)}
      {footerIndustries.map((industry) => <a href={`/${locale}/industries/${industry.slug}/`}>{industry.title}</a>)}
    </div>
    <div>
      <h2>{footerUi.legal}</h2>
      <a href="/privacy/">{legalLinks.privacy}</a>
      <a href="/impressum/">{legalLinks.impressum}</a>
    </div>
    <div>
      <h2>{footerUi.social}</h2>
      <div class="footer-social-icons">
        {socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label} data-track-event="social_footer_click" data-track-label={link.label}>
            <svg viewBox="0 0 28 28" aria-hidden="true" focusable="false">
              <path d={link.path} />
            </svg>
          </a>
        ))}
      </div>
    </div>
    <div class="footer-newsletter" id="newsletter">
      <h2>{newsletterUi.title}</h2>
      <p>{newsletterUi.text}</p>
      <form data-newsletter-form data-newsletter-campaign="newsletter" novalidate>
        <input name="campaign" type="hidden" value="newsletter" />
        <label class="website-field" aria-hidden="true">
          Website
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <label>
          <span>{newsletterUi.email}</span>
          <input name="email" type="email" autocomplete="email" required />
        </label>
        <label class="newsletter-consent">
          <input name="privacyPolicyAccepted" type="checkbox" value="yes" required />
          <span>{newsletterUi.consent} <a href="/privacy/" target="_blank" rel="noopener">{legalLinks.privacy}</a></span>
        </label>
        <button class="button secondary" type="submit">{newsletterUi.button}</button>
        <p class="newsletter-status" data-newsletter-status aria-live="polite"></p>
      </form>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {currentYear} Websiteli. {footerUi.rights}</p>
  </div>
</footer>

<div class="popup-backdrop" data-popup-backdrop hidden></div>

<section class="conversion-popup" data-newsletter-popup role="dialog" aria-modal="true" aria-labelledby="newsletter-popup-title" hidden>
  <button class="popup-close" type="button" data-popup-close aria-label="Close">×</button>
  <p class="eyebrow">Newsletter</p>
  <h2 id="newsletter-popup-title">Get 20% off your website</h2>
  <p>Join the Websiteli newsletter and receive a 20% discount code for your first website project.</p>
  <form data-newsletter-form data-popup-newsletter-form data-newsletter-campaign="newsletter" novalidate>
    <input name="campaign" type="hidden" value="newsletter" />
    <label class="website-field" aria-hidden="true">
      Website
      <input name="website" tabindex="-1" autocomplete="off" />
    </label>
    <label>
      <span>Email</span>
      <input name="email" type="email" autocomplete="email" required />
    </label>
    <label class="newsletter-consent">
      <input name="privacyPolicyAccepted" type="checkbox" value="yes" required />
      <span>I accept the <a href="/privacy/" target="_blank" rel="noopener">Privacy Policy</a></span>
    </label>
    <button class="button primary" type="submit">Get my 20% discount</button>
    <button class="popup-link" type="button" data-popup-dismiss>No thanks</button>
    <p class="newsletter-status" data-newsletter-status aria-live="polite"></p>
  </form>
</section>

<section class="conversion-popup" data-exit-popup role="dialog" aria-modal="true" aria-labelledby="exit-popup-title" hidden>
  <button class="popup-close" type="button" data-popup-close aria-label="Close">×</button>
  <p class="eyebrow">Free audit</p>
  <h2 id="exit-popup-title">Before you go — want a free website audit?</h2>
  <p>Tell us about your business and we’ll show you how your website could attract more customers.</p>
  <div class="popup-actions">
    <a class="button primary" href={`/${locale}/contact/?package=digitalAudit&project=portfolio&intent=digital_audit`} data-exit-popup-cta>Get my free audit</a>
    <button class="popup-link" type="button" data-popup-dismiss>Maybe later</button>
  </div>
</section>

<script define:vars={{ newsletterUi }}>
  const newsletterForms = Array.from(document.querySelectorAll("[data-newsletter-form]"));

  function getNewsletterString(formData, key) {
    return String(formData.get(key) || "").trim();
  }

  newsletterForms.forEach((newsletterForm) => newsletterForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    window.websiteliUpdateInquiryFields?.();
    const newsletterStatus = newsletterForm.querySelector("[data-newsletter-status]");

    const formData = new FormData(newsletterForm);
    const email = getNewsletterString(formData, "email");
    const honeypot = getNewsletterString(formData, "website");
    const privacyAccepted = getNewsletterString(formData, "privacyPolicyAccepted") === "yes";
    const submitButton = newsletterForm.querySelector("button[type='submit']");
    const campaign = newsletterForm.getAttribute("data-newsletter-campaign") || getNewsletterString(formData, "campaign") || "newsletter";
    const successMessage = newsletterForm.getAttribute("data-newsletter-success") || newsletterUi.success;
    const eventLabel = newsletterForm.getAttribute("data-newsletter-event-label") || "Newsletter";
    const sourceUrl = window.location.href;
    const language = document.documentElement.lang || "en";

    if (honeypot) {
      newsletterForm.reset();
      if (newsletterStatus) newsletterStatus.textContent = successMessage;
      return;
    }

    if (!newsletterForm.checkValidity() || !email || !privacyAccepted) {
      newsletterForm.reportValidity();
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.validation;
      return;
    }

    const attribution = window.websiteliGetAttribution?.() || {};
    const detectedCountry = window.websiteliPricing?.country || "";
    const detectedCurrency = window.websiteliPricing?.currency || "";
    const detectedMarket = window.websiteliPricing?.pricingMarket || "";
    const payload = {
      type: "newsletter",
      email,
      campaign,
      sourceUrl,
      language,
      website: honeypot,
      metadata: {
        language,
        country: detectedCountry,
        currency: detectedCurrency,
        market: detectedMarket,
        pageUrl: sourceUrl,
        referrer: document.referrer,
        userAgent: navigator.userAgent,
        campaign,
        utm_source: attribution.utm_source || "",
        utm_medium: attribution.utm_medium || "",
        utm_campaign: attribution.utm_campaign || "",
        utm_term: attribution.utm_term || "",
        utm_content: attribution.utm_content || "",
        utm_id: attribution.utm_id || "",
        gclid: attribution.gclid || "",
        gbraid: attribution.gbraid || "",
        wbraid: attribution.wbraid || "",
        fbclid: attribution.fbclid || "",
        msclkid: attribution.msclkid || "",
        landingPage: attribution.landingPage || "",
        firstSeenAt: attribution.firstSeenAt || "",
        first_utm_source: attribution.first_utm_source || "",
        first_utm_medium: attribution.first_utm_medium || "",
        first_utm_campaign: attribution.first_utm_campaign || "",
        first_gclid: attribution.first_gclid || "",
        first_fbclid: attribution.first_fbclid || "",
        privacyPolicyAccepted: privacyAccepted,
        privacyPolicyVersion: "2026-06-24",
        privacyPolicyUrl: `${window.location.origin}/privacy/`,
        timestamp: new Date().toISOString(),
      },
    };

    submitButton?.setAttribute("disabled", "true");
    if (newsletterStatus) newsletterStatus.textContent = newsletterUi.sending;

    try {
      await fetch("https://script.google.com/macros/s/AKfycbyAMZy4vPe56lUmFA8-Q_MDJ-AS4aJJb0vOeiViGPneWtkYn9LKXla2BmSWflsvuE-lyw/exec", {
        method: "POST",
        mode: "no-cors",
        headers: {
          "Content-Type": "text/plain;charset=utf-8",
        },
        body: JSON.stringify(payload),
      });

      newsletterForm.reset();
      window.trackWebsiteliEvent?.("newsletter_subscribe", {
        event_category: "lead",
        event_label: eventLabel,
        campaign: payload.campaign,
        locale: payload.language,
        country: payload.metadata.country,
        pricing_market: payload.metadata.market,
        currency: payload.metadata.currency,
        source_path: window.location.pathname,
        utm_source: payload.metadata.utm_source,
        utm_medium: payload.metadata.utm_medium,
        utm_campaign: payload.metadata.utm_campaign,
        privacy_policy_accepted: "yes",
      });
      if (newsletterForm.hasAttribute("data-popup-newsletter-form")) {
        localStorage.setItem("websiteli_newsletter_popup_subscribed", "true");
        localStorage.setItem("websiteli_newsletter_popup_dismissed", "true");
        window.trackWebsiteliEvent?.("newsletter_popup_submit", {
          event_category: "lead",
          event_label: "Newsletter discount popup",
        });
        window.websiteliCloseConversionPopup?.("newsletter");
      }
      if (newsletterStatus) newsletterStatus.textContent = successMessage;
    } catch (error) {
      if (newsletterStatus) newsletterStatus.textContent = newsletterUi.error;
      console.error(error);
    } finally {
      submitButton?.removeAttribute("disabled");
    }
  }));
</script>

<script>
  const popupState = {
    activePopup: null,
    previousFocus: null,
    newsletterTimer: null,
    exitShownThisPage: false,
    newsletterShownThisPage: false,
  };
  // Set to true when the exit-intent audit popup should be active again.
  const enableExitPopup = false;
  const popupBackdrop = document.querySelector("[data-popup-backdrop]");
  const newsletterPopup = document.querySelector("[data-newsletter-popup]");
  const exitPopup = document.querySelector("[data-exit-popup]");
  const focusableSelector = "a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex='-1'])";

  function hasPopupFlag(key) {
    try {
      return localStorage.getItem(key) === "true";
    } catch {
      return false;
    }
  }

  function setPopupFlag(key) {
    try {
      localStorage.setItem(key, "true");
    } catch {}
  }

  function setPopupValue(key, value) {
    try {
      localStorage.setItem(key, value);
    } catch {}
  }

  function trackPopupEvent(name, label) {
    window.trackWebsiteliEvent?.(name, {
      event_category: "engagement",
      event_label: label,
    });
  }

  function getFocusable(popup) {
    return Array.from(popup.querySelectorAll(focusableSelector)).filter((item) => item instanceof HTMLElement && !item.hasAttribute("hidden"));
  }

  function openPopup(kind) {
    const popup = kind === "newsletter" ? newsletterPopup : exitPopup;
    if (!(popup instanceof HTMLElement) || !(popupBackdrop instanceof HTMLElement) || popupState.activePopup) return;

    popupState.previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    popupState.activePopup = { kind, element: popup };
    if (kind === "newsletter") {
      popupState.newsletterShownThisPage = true;
      setPopupValue("websiteli_newsletter_popup_last_shown", String(Date.now()));
    }
    popup.hidden = false;
    popupBackdrop.hidden = false;
    document.documentElement.classList.add("has-conversion-popup");
    getFocusable(popup)[0]?.focus();
    trackPopupEvent(kind === "newsletter" ? "newsletter_popup_view" : "exit_popup_view", kind === "newsletter" ? "Newsletter discount popup" : "Exit audit popup");
  }

  function closePopup(reason = "dismiss") {
    const active = popupState.activePopup;
    if (!active) return;
    const shouldShowExitAfterNewsletterDismiss =
      enableExitPopup &&
      reason === "dismiss" &&
      active.kind === "newsletter" &&
      !hasPopupFlag("websiteli_exit_popup_dismissed");

    active.element.hidden = true;
    if (popupBackdrop instanceof HTMLElement) popupBackdrop.hidden = true;
    document.documentElement.classList.remove("has-conversion-popup");
    popupState.activePopup = null;
    try {
      popupState.previousFocus?.focus();
    } catch {}
    if (reason === "dismiss") {
      if (active.kind === "newsletter") {
        setPopupFlag("websiteli_newsletter_popup_dismissed");
        trackPopupEvent("newsletter_popup_dismiss", "Newsletter discount popup");
      } else {
        setPopupFlag("websiteli_exit_popup_dismissed");
        trackPopupEvent("exit_popup_dismiss", "Exit audit popup");
      }
    }
    if (shouldShowExitAfterNewsletterDismiss) {
      window.setTimeout(() => {
        popupState.exitShownThisPage = true;
        openPopup("exit");
      }, 250);
    }
  }

  window.websiteliCloseConversionPopup = closePopup;

  document.addEventListener("keydown", (event) => {
    if (!popupState.activePopup) return;
    if (event.key === "Escape") {
      event.preventDefault();
      closePopup("dismiss");
      return;
    }
    if (event.key !== "Tab") return;

    const focusable = getFocusable(popupState.activePopup.element);
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  });

  function handleDismissClick(event) {
    const target = event.target instanceof Element ? event.target : null;
    if (!target) return;
    if (target.closest("[data-popup-close], [data-popup-dismiss]") || target.matches("[data-popup-backdrop]")) {
      event.preventDefault();
      event.stopPropagation();
      closePopup("dismiss");
    }
  }

  document.addEventListener("click", handleDismissClick, true);
  document.querySelectorAll("[data-popup-close], [data-popup-dismiss]").forEach((control) => {
    control.addEventListener("click", handleDismissClick);
  });
  popupBackdrop?.addEventListener("click", handleDismissClick);

  document.querySelector("[data-exit-popup-cta]")?.addEventListener("click", () => {
    setPopupFlag("websiteli_exit_popup_dismissed");
    trackPopupEvent("exit_popup_cta_click", "Exit audit popup");
  });

  function canShowNewsletterPopup() {
    return !hasPopupFlag("websiteli_newsletter_popup_dismissed") && !hasPopupFlag("websiteli_newsletter_popup_subscribed");
  }

  function canShowExitPopup() {
    return (
      enableExitPopup &&
      !popupState.activePopup &&
      !popupState.exitShownThisPage &&
      !hasPopupFlag("websiteli_exit_popup_dismissed") &&
      !canShowNewsletterPopup()
    );
  }

  if (canShowNewsletterPopup()) {
    popupState.newsletterTimer = window.setTimeout(() => openPopup("newsletter"), 30000);
  }

  document.addEventListener("mousemove", (event) => {
    if (event.clientY > 18 || !canShowExitPopup()) return;
    popupState.exitShownThisPage = true;
    openPopup("exit");
  });

  let deepestScroll = 0;
  document.addEventListener("scroll", () => {
    const scrollable = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
    deepestScroll = Math.max(deepestScroll, window.scrollY / scrollable);
    if (deepestScroll < 0.72 || !canShowExitPopup() || !window.matchMedia("(pointer: coarse)").matches) return;
    popupState.exitShownThisPage = true;
    openPopup("exit");
  }, { passive: true });

  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState !== "visible" || !canShowExitPopup()) return;
    popupState.exitShownThisPage = true;
    window.setTimeout(() => openPopup("exit"), 800);
  });
</script>
