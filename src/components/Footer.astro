---
import { futurePages } from "../content/site";

const currentYear = new Date().getFullYear();
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL || "/#contact";
---

<footer class="site-footer">
  <div class="footer-main">
    <a class="brand" href="/#home" aria-label="websiteli.ch home">
      <span class="brand-mark">w</span>
      <span>Websiteli</span>
    </a>
    <p>Simple, modern websites for Swiss small businesses. Clear pricing, friendly support, and room to grow.</p>
  </div>

  <div class="footer-links" aria-label="Footer links">
    <div>
      <h2>Contact</h2>
      <a href="mailto:hello@websiteli.ch" data-track-event="email_click" data-track-label="Footer email">hello@websiteli.ch</a>
      <a href="mailto:jenifer.tabita.ciuciu.kiss@gmail.com" data-track-event="email_click" data-track-label="Footer alternate email">jenifer.tabita.ciuciu.kiss@gmail.com</a>
      <a href={whatsappUrl} data-track-event="whatsapp_click" data-track-label="Footer WhatsApp" rel="noopener">WhatsApp</a>
    </div>
    <div>
      <h2>Future pages</h2>
      {futurePages.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
    <div>
      <h2>Legal</h2>
      <a href="/privacy/">Privacy Policy</a>
      <a href="/impressum/">Impressum</a>
    </div>
    <div>
      <h2>Social</h2>
      <span>Links coming soon</span>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {currentYear} Websiteli. All rights reserved.</p>
  </div>
</footer>
