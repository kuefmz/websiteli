---
import ThemeToggle from "./ThemeToggle.astro";
import { getLocalizedPath, localeCodes, pageNavKeys } from "../content/locales";

interface Props {
  content?: any;
  locale?: string;
  page?: string;
  languageLinks?: { locale: string; href: string }[];
}

const { content, locale = "en", page = "home", languageLinks = [] } = Astro.props;
const nav = content?.nav ?? {
  home: "Home",
  servicesPricing: "Services & Pricing",
  portfolio: "Portfolio",
  blog: "Blog",
  about: "About",
  contact: "Contact",
};
const navItems = [
  { label: nav.home, href: `/${locale}/` },
  { label: nav.servicesPricing ?? "Services & Pricing", href: `/${locale}/services-pricing/` },
  { label: nav.portfolio ?? "Portfolio", href: `/${locale}/portfolio/` },
  { label: nav.blog ?? "Blog", href: `/${locale}/blog/` },
  { label: nav.about, href: `/${locale}/about/` },
];
const quoteHref = `/${locale}/contact/`;
const demosHref = `/${locale}/portfolio/`;
const switchPage = page === "home" || page in pageNavKeys ? page : "home";
const languageLinkByLocale = new Map(languageLinks.map((item) => [item.locale, item.href]));
const headerLabels = {
  en: { mainNav: "Main navigation", language: "Language switcher", openMenu: "Open menu", mobileNav: "Mobile navigation", home: "websiteli.ch home" },
  de: { mainNav: "Hauptnavigation", language: "Sprachauswahl", openMenu: "Menü öffnen", mobileNav: "Mobile Navigation", home: "websiteli.ch Startseite" },
  hu: { mainNav: "Fő navigáció", language: "Nyelvválasztó", openMenu: "Menü megnyitása", mobileNav: "Mobil navigáció", home: "websiteli.ch kezdőlap" },
  pl: { mainNav: "Nawigacja główna", language: "Wybór języka", openMenu: "Otwórz menu", mobileNav: "Nawigacja mobilna", home: "strona główna websiteli.ch" },
  es: { mainNav: "Navegación principal", language: "Selector de idioma", openMenu: "Abrir menú", mobileNav: "Navegación móvil", home: "inicio de websiteli.ch" },
  fr: { mainNav: "Navigation principale", language: "Sélecteur de langue", openMenu: "Ouvrir le menu", mobileNav: "Navigation mobile", home: "accueil websiteli.ch" },
  it: { mainNav: "Navigazione principale", language: "Selettore lingua", openMenu: "Apri menu", mobileNav: "Navigazione mobile", home: "home websiteli.ch" },
  cz: { mainNav: "Hlavní navigace", language: "Výběr jazyka", openMenu: "Otevřít menu", mobileNav: "Mobilní navigace", home: "domů websiteli.ch" },
  sk: { mainNav: "Hlavná navigácia", language: "Výber jazyka", openMenu: "Otvoriť menu", mobileNav: "Mobilná navigácia", home: "domov websiteli.ch" },
  pt: { mainNav: "Navegação principal", language: "Seletor de idioma", openMenu: "Abrir menu", mobileNav: "Navegação móvel", home: "início websiteli.ch" },
  da: { mainNav: "Hovednavigation", language: "Sprogvælger", openMenu: "Åbn menu", mobileNav: "Mobilnavigation", home: "websiteli.ch forside" },
  nl: { mainNav: "Hoofdnavigatie", language: "Taalkeuze", openMenu: "Menu openen", mobileNav: "Mobiele navigatie", home: "websiteli.ch startpagina" },
  ja: { mainNav: "メインナビゲーション", language: "言語切り替え", openMenu: "メニューを開く", mobileNav: "モバイルナビゲーション", home: "websiteli.ch ホーム" },
} as const;
const headerCopy = headerLabels[locale as keyof typeof headerLabels] ?? headerLabels.en;
---

<header class="site-header" data-header>
  <a class="brand" href={`/${locale}/`} aria-label={headerCopy.home}>
    <span class="brand-mark"><img src="/assets/websiteli-logo.png" alt="" width="36" height="36" /></span>
    <span>websiteli.ch</span>
  </a>

  <nav class="desktop-nav" aria-label={headerCopy.mainNav}>
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>

  <div class="header-actions">
    <div class="language-switcher" aria-label={headerCopy.language}>
      <button type="button" aria-expanded="false" data-language-toggle>{locale.toUpperCase()}</button>
      <div class="language-menu" data-language-menu>
        {
          localeCodes.map((code) => (
            <a href={languageLinkByLocale.get(code) ?? getLocalizedPath(code, switchPage as any)} aria-current={code === locale ? "true" : undefined}>{code.toUpperCase()}</a>
          ))
        }
      </div>
    </div>
    <ThemeToggle locale={locale} />
    <a class="header-demo" href={demosHref} data-track-event="demo_nav_click" data-track-label="Header demos">{content?.ui?.demoCta ?? "See Live Demos"}</a>
    <a class="header-quote" href={quoteHref} data-track-event="quote_button_click" data-track-label="Header quote">{nav.contact}</a>
    <button class="menu-toggle" type="button" aria-label={headerCopy.openMenu} aria-expanded="false" data-menu-toggle>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<nav class="mobile-nav" aria-label={headerCopy.mobileNav} data-mobile-nav>
  {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  <div class="mobile-languages">
    {localeCodes.map((code) => <a href={languageLinkByLocale.get(code) ?? getLocalizedPath(code, switchPage as any)}>{code.toUpperCase()}</a>)}
  </div>
  <a class="mobile-demo" href={demosHref} data-track-event="demo_nav_click" data-track-label="Mobile demos">{content?.ui?.demoCta ?? "See Live Demos"}</a>
  <a class="mobile-quote" href={quoteHref} data-track-event="quote_button_click" data-track-label="Mobile quote">{nav.contact}</a>
</nav>

<script>
  const header = document.querySelector("[data-header]");
  const menuToggle = document.querySelector("[data-menu-toggle]");
  const mobileNav = document.querySelector("[data-mobile-nav]");
  let lastScrollY = window.scrollY;
  let ticking = false;

  const updateHeader = () => {
    if (!header) return;

    const currentScrollY = window.scrollY;
    const isScrolled = currentScrollY > 12;
    const isScrollingDown = currentScrollY > lastScrollY;
    const menuIsOpen = mobileNav?.classList.contains("is-open");

    header.classList.toggle("is-scrolled", isScrolled);
    header.classList.toggle("is-hidden", isScrolled && isScrollingDown && !menuIsOpen);

    lastScrollY = Math.max(currentScrollY, 0);
    ticking = false;
  };

  updateHeader();
  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        window.requestAnimationFrame(updateHeader);
        ticking = true;
      }
    },
    { passive: true },
  );

  menuToggle?.addEventListener("click", () => {
    const isOpen = mobileNav?.classList.toggle("is-open") ?? false;
    menuToggle.setAttribute("aria-expanded", String(isOpen));
    header?.classList.remove("is-hidden");
  });

  mobileNav?.addEventListener("click", (event) => {
    if (event.target instanceof HTMLAnchorElement) {
      mobileNav.classList.remove("is-open");
      menuToggle?.setAttribute("aria-expanded", "false");
    }
  });

  document.querySelector("[data-language-toggle]")?.addEventListener("click", () => {
    document.querySelector("[data-language-menu]")?.classList.toggle("is-open");
  });
</script>
