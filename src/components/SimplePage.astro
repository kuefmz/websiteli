---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<main class="simple-page section-shell">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p>{description}</p>
  <a class="button secondary" href="/">Back home</a>
</main>
